# syntax=docker/dockerfile:1.7

FROM openmodelica/openmodelica:v1.24.5-ompython

USER root

RUN apt-get update && apt-get install -y \
    curl \
    sudo \
    ca-certificates \
    && rm -rf /var/lib/apt/lists/*

RUN useradd --create-home --shell /bin/bash appuser && \
    usermod -aG sudo appuser && \
    echo "appuser ALL=(ALL) NOPASSWD: ALL" >> /etc/sudoers

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1 \
    PYTHONPATH=/opt/tricys-src \
    HDF5_VISUALIZER_PORT=8050 \
    HDF5_VISUALIZER_BASE_URL=/hdf5/ \
    HDF5_CONTEXTS_DIR=/data/hdf5_contexts

WORKDIR /opt/tricys-src

COPY tricys /opt/tricys-src/tricys
COPY script/modelica_install /opt/tricys-src/script/modelica_install
COPY --chown=appuser:appuser docker/requirements/requirements-hdf5.txt /tmp/requirements-hdf5.txt
COPY docker/scripts/tricys_hdf5_entrypoint.sh /usr/local/bin/tricys_hdf5_entrypoint.sh
COPY docker/scripts/tricys_hdf5_cli.sh /usr/local/bin/tricys

RUN chmod +x /usr/local/bin/tricys_hdf5_entrypoint.sh /usr/local/bin/tricys && \
    mkdir -p /data/hdf5_contexts && \
    chown -R appuser:appuser /opt/tricys-src /data /home/appuser

USER appuser

RUN python3 -m pip install --upgrade pip setuptools wheel && \
    python3 -m pip install -r /tmp/requirements-hdf5.txt && \
    omc script/modelica_install/install.mos && \
    rm -f /tmp/requirements-hdf5.txt

WORKDIR /data

EXPOSE 8050

HEALTHCHECK CMD sh -lc 'curl -fsS "http://127.0.0.1:${HDF5_VISUALIZER_PORT:-8050}${HDF5_VISUALIZER_BASE_URL:-/hdf5/}health" || exit 1'

ENTRYPOINT ["/usr/local/bin/tricys_hdf5_entrypoint.sh"]
